{
  "name": "borgstein/logstream-laravel",
  "description": "Laravel client for the Logstream logging API",
  "type": "library",
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0",
    "illuminate/http": "^10.0|^11.0",
    "illuminate/queue": "^10.0|^11.0",
    "illuminate/log": "^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "pestphp/pest": "^2.0",
    "pestphp/pest-plugin-laravel": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Logstream\\Laravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Logstream\\Laravel\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": ["Logstream\\Laravel\\LogstreamServiceProvider"],
      "aliases": {
        "Logstream": "Logstream\\Laravel\\Facades\\Logstream"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
